# Auto_bookmark 环境配置文件
# 复制此文件为 .env 并根据需要修改配置值

# ==================== 输入/输出配置 ====================

# 书签 HTML 文件路径（可选，命令行参数优先级更高）
# INPUT_BOOKMARKS_PATH=./bookmarks.html

# 输出目录（Markdown 转换和本地镜像同步的默认输出目录）
OUTPUT_DIR=./output

# 本地镜像同步目录（默认同步到 bookmarks_mirror）
SYNC_DIR=./bookmarks_mirror

# ==================== 服务器配置 ====================

# Web 服务器默认端口
PORT=3000

# 端口查找起始端口（当 PORT 不可用时，从这里开始递增查找）
START_PORT=3000

# 端口查找最大尝试次数
MAX_PORT_ATTEMPTS=50

# ==================== 并发和超时配置 ====================

# 最大并发请求数（用于 URL 检测和图标下载）
MAX_CONCURRENCY=5

# URL 检测超时时间（毫秒）
URL_TIMEOUT=5000

# 图标下载超时时间（毫秒）
ICON_TIMEOUT=10000

# ==================== 过滤规则配置 ====================

# 需要过滤的 URL 模式（使用逗号分隔）
# 支持字符串匹配，匹配 URL 中包含的任意部分
FILTER_PATTERNS=localhost,127.0.0.1,dev.test

# ==================== 调试和日志配置 ====================

# 是否启用调试模式（true/false）
DEBUG=false

# 日志级别（info, warn, error, debug）
LOG_LEVEL=info
